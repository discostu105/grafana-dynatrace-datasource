{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Dynatracegrail",
  "id": "discostu105-dynatracegrail-datasource",
  "metrics": true,
  "logs": true,
  "tracing": true,
  "alerting": true,
  "annotations": true,
  "backend": true,
  "executable": "gpx_dynatracegrail",
  "info": {
    "description": "Query Dynatrace Grail with DQL — timeseries, table, log, and event panels from a Dynatrace platform tenant.",
    "author": {
      "name": "Discostu105"
    },
    "keywords": ["dynatrace", "dql", "grail", "observability", "metrics"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      { "name": "GitHub", "url": "https://github.com/discostu105/grafana-dynatrace-datasource" },
      { "name": "Issues", "url": "https://github.com/discostu105/grafana-dynatrace-datasource/issues" },
      { "name": "DQL reference", "url": "https://docs.dynatrace.com/docs/discover-dynatrace/references/dynatrace-query-language" }
    ],
    "screenshots": [
      { "name": "Energy overview", "path": "img/screenshot-energy.png" },
      { "name": "Climate environment", "path": "img/screenshot-climate.png" },
      { "name": "Miniserver health", "path": "img/screenshot-miniserver.png" }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}
