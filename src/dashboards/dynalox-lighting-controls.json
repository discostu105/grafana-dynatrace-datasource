    "dql",
    "dynalox"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "DS_DYNATRACEGRAIL",
        "type": "datasource",
        "label": "Dynatrace",
        "query": "discostu105-dynatracegrail-datasource",
        "current": {
          "text": "Dynatrace",
          "value": "Dynatrace"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Light Meter Details",
      "datasource": {
        "type": "discostu105-dynatracegrail-datasource",
        "uid": "${DS_DYNATRACEGRAIL}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "discostu105-dynatracegrail-datasource",
            "uid": "${DS_DYNATRACEGRAIL}"
          },
          "dqlQuery": "timeseries val = avg(loxone.control.value), filter: { control.category == \"Energie\" AND unit == \"kW\"\n  AND contains(control.name, \"Licht\") },\nby: { control.name, control.room, state.name }\n| fieldsAdd latest = arrayLast(val)\n| filter isNotNull(latest)\n| filter state.name == \"actual\" OR state.name == \"totalDay\" OR state.name == \"totalMonth\"\n| fieldsAdd metric = if(state.name == \"actual\", \"Current Power\", else: if(state.name == \"totalDay\", \"Today\", else: \"This Month\"))\n| fields control.name, control.room, metric, latest\n| sort control.name, metric"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "lastNotNull"
            ]
          }
        }
      ]
    },
    {
