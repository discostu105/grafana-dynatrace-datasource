{
  "title": "DynaLox - Miniserver health",
  "uid": "dynalox-miniserver-health",
  "schemaVersion": 39,
  "version": 1,
  "tags": [
    "dql",
    "dynalox"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "control",
        "type": "query",
        "label": "Control",
        "datasource": {
          "type": "discostu105-dynatracegrail-datasource",
          "uid": "P6C323D126547F71F"
        },
        "query": "fetch metric.series | filter contains(metric.key, \"loxone.control\") | summarize count(), by:{control.name} | fields control.name | sort control.name asc",
        "refresh": 1,
        "regex": "",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CAN Bus Errors",
      "datasource": {
        "type": "discostu105-dynatracegrail-datasource",
        "uid": "P6C323D126547F71F"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "discostu105-dynatracegrail-datasource",
            "uid": "P6C323D126547F71F"
          },
          "dqlQuery": "timeseries {\n  receive_errors = avg(loxone.can.receive_errors),\n  frame_errors = avg(loxone.can.frame_errors),\n  overruns = avg(loxone.can.overruns)\n}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
